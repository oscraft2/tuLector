NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Correo transaccional (invitaciones, alertas de cuota, pagos, bienvenida,
# comprobantes, confirmacion de leads). Sin estas dos variables, el sistema
# cae automaticamente a modo dev-log: los correos se imprimen por consola en
# vez de enviarse de verdad (ver src/lib/email.ts). Consigue el API key en
# https://resend.com/api-keys (requiere verificar un dominio propio primero
# para no quedar limitado al remitente sandbox onboarding@resend.dev). Ver
# docs/plan-correo-email.md para el detalle completo del sistema de correo.
RESEND_API_KEY=re_tu_api_key_aqui
RESEND_FROM_EMAIL=notificaciones@tudominio.com
