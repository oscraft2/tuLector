<?xml version="1.0" encoding="utf-8"?>
<!--
  Android < 12 (API < 31) usa este archivo para Auto Backup. La app maneja
  RUT y respuestas de alumnos (menores) en SharedPreferences (offline queue) —
  se excluye todo dominio local del backup automatico. Ver SECURITY_PROMPT_APK.md Tarea B.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
